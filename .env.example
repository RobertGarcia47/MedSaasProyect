# ── Supabase (requeridas: auth, DB, storage) ─────────────────────────────────
# Mismo proyecto que el onboarding (ref: esvhhkwgquffdxkuoimt) — comparten DB.
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_xxx"

# ── API de reportes / PDF (ApiMedsaas + QuestPDF) ────────────────────────────
# Genera los PDF de receta. Producción: https://apimedsaas.recysoft.com.mx
# En local (perfil http) corre en http://localhost:5128, que es el valor por defecto
# si no se define esta variable.
VITE_REPORTES_API_URL="https://apimedsaas.recysoft.com.mx"

# ── Firebase (legado: se eliminará al completar la migración a Supabase) ───────
